{
  "name": "tablex",
  "version": "0.0.0",
  "license": "MIT",
  "author": {
    "name": "Kareem Ebrahim"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kareemmahlees/tablex"
  },
  "private": true,
  "scripts": {
    "desktop:dev": "pnpm -F @tablex/desktop exec tauri dev",
    "desktop:debug": "pnpm -F @tablex/desktop exec tauri build --debug",
    "desktop:build": "pnpm -F @tablex/desktop exec tauri build",
    "desktop:info": "pnpm -F @tablex/desktop exec tauri info",
    "web:dev": "pnpm -F @tablex/web dev",
    "web:check": "pnpm -F @tablex/web check",
    "web:build": "pnpm -F @tablex/web build",
    "web:preview": "pnpm -F @tablex/web preview",
    "lint": "pnpm oxlint .",
    "lint:fix": "pnpm oxlint . --fix",
    "rust:lint": "cargo clippy",
    "fmt": "pnpm oxfmt . --check",
    "fmt:fix": "pnpm oxfmt ."
  },
  "devDependencies": {
    "@j178/prek": "^0.3.10",
    "@types/node": "^20.17.19",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@11.0.0",
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.292.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss-animate": "^1.0.7",
    "timescape": "^0.7.1"
  }
}
